{
    "name": "d3lph1/l-shop",
    "description": "Modern e-commerce system for Minecraft.",
    "keywords": ["shop", "e-shop", "e-commerce", "trading", "bukkit", "minecraft", "l-shop", "laravel"],
    "authors": [
        {
            "name": "Chertkov Bogdan",
            "email": "d3lph1.contact@gmail.com",
            "homepage": "https://github.com/D3lph1",
            "role": "Backend/Frontend developing"
        },
        {
            "name": "Vlasov Michael",
            "homepage": "https://github.com/Whiled0S",
            "role": "Design, layout, frontend developing"
        }
    ],
    "license": "MIT",
    "type": "project",
    "require": {
        "php": ">=8.1.0",
        "ext-json": "*",
        "ext-PDO": "*",
        "beberlei/DoctrineExtensions": "^2.0",
        "d3lph1/minecraft-rcon-manager": "^1.3",
        "laravel/framework": "^11.0",
        "laravel/tinker": "^2.8",
        "intervention/image": "^3.0"
    },
    "require-dev": {
        "laravel/pint": "^1.13",
        "fakerphp/faker": "^1.23",
        "mockery/mockery": "^1.6",
        "phpunit/phpunit": "^10.5",
        "laravel/sail": "^1.26"
    },
    "autoload": {
        "classmap": [
            "database/seeds",
            "database/factories"
        ],
        "psr-4": {
            "App\\": "app/"
        },
        "files": [
            "app/helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "dont-discover": [
            ]
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi"
        ],
        "serve": [
            "@php artisan serve"
        ],
        "build": [
            "npm run build",
            "@php artisan cache:clear"
        ]
    },
    "config": {
        "preferred-install": "dist",
        "sort-packages": true,
        "optimize-autoloader": true
    }
}
